# Copy to .env and fill in. Used by docker-compose.yml.

# Postgres password for the spalt role (db service + spaltd's DSN).
POSTGRES_PASSWORD=

# At-rest encryption key: base64-encoded 32 bytes. Strongly recommended.
# Without it spaltd still starts but stores secrets (provider API keys,
# plugin credentials) in plaintext. Generate once and keep it safe;
# changing it makes existing encrypted data unreadable.
#   openssl rand -base64 32
# (or, after building the image: docker run --rm spalt:latest spalt genkey)
SPALT_MASTER_KEY=

# --- optional ---

# Host port to publish spaltd on (container always listens on 8080).
SPALT_PORT=8080

# Public origin clients prepend to signed file URLs. Set when behind a
# reverse proxy, e.g. https://spalt.example.com
SPALT_PUBLIC_BASE_URL=

# Auto-create an admin on first boot against an empty database. Leave
# blank to create users manually with `docker compose -p spalt exec spaltd
# spalt useradd -u <name>`.
SPALT_BOOTSTRAP_ADMIN_USERNAME=
SPALT_BOOTSTRAP_ADMIN_PASSWORD=
