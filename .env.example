# Copy to .env and fill in. Used by docker-compose.yml.

# Postgres password for the reeve role (db service + reeved's DSN).
POSTGRES_PASSWORD=

# At-rest encryption key — base64-encoded 32 bytes. REQUIRED.
# Generate once and keep it safe; changing it makes existing encrypted
# data (provider API keys, plugin secrets) unreadable.
#   openssl rand -base64 32
# (or, after building the image: docker run --rm reeve:latest reeve genkey)
REEVE_MASTER_KEY=

# --- optional ---

# Host port to publish reeved on (container always listens on 8080).
REEVE_PORT=8080

# Public origin clients prepend to signed file URLs. Set when behind a
# reverse proxy, e.g. https://reeve.example.com
REEVE_PUBLIC_BASE_URL=

# Auto-create an admin on first boot against an empty database. Leave
# blank to create users manually with `docker compose exec reeved reeve
# useradd -u <name>`.
REEVE_BOOTSTRAP_ADMIN_USERNAME=
REEVE_BOOTSTRAP_ADMIN_PASSWORD=
