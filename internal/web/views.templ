package web

import "strings"

// layout is the base HTML shell. htmx (plus its SSE extension) progressively
// enhances the page; without JS it still works (forms POST, links navigate).
templ layout(title string) {
	<!DOCTYPE html>
	<html lang="en">
		<head>
			<meta charset="utf-8"/>
			<meta name="viewport" content="width=device-width, initial-scale=1"/>
			<title>{ title }</title>
			<link rel="stylesheet" href="/web-assets/app.css"/>
			<script src="/web-assets/htmx.min.js"></script>
			<script src="/web-assets/sse.js"></script>
		</head>
		<body>
			{ children... }
		</body>
	</html>
}

templ loginPage(errMsg string) {
	@layout("Sign in — Reeve") {
		<main class="auth">
			<form class="card" method="post" action="/login">
				<h1 class="brand">Reeve</h1>
				if errMsg != "" {
					<p class="error">{ errMsg }</p>
				}
				<label>
					Username
					<input name="username" autocomplete="username" autofocus/>
				</label>
				<label>
					Password
					<input name="password" type="password" autocomplete="current-password"/>
				</label>
				<button type="submit">Sign in</button>
			</form>
		</main>
	}
}

templ sidebar(convos []convoVM) {
	<aside class="sidebar">
		<header class="sidebar-head">
			<a class="brand" href="/chats">Reeve</a>
			<div class="sidebar-actions">
				<a class="new-chat" href="/new">+ New</a>
				<a class="link" href="/settings">Settings</a>
				<form method="post" action="/logout">
					<button class="link" type="submit">Sign out</button>
				</form>
			</div>
		</header>
		<nav class="convo-list">
			for _, c := range convos {
				<a class={ "convo", templ.KV("active", c.Active) } href={ templ.SafeURL("/c/" + c.ID) }>
					{ c.Title }
				</a>
			}
			if len(convos) == 0 {
				<p class="muted pad">No conversations yet.</p>
			}
		</nav>
	</aside>
}

templ chatsPage(convos []convoVM) {
	@layout("Chats — Reeve") {
		<div class="app">
			@sidebar(convos)
			<main class="main empty">
				<p class="muted">Select a conversation, or <a href="/new">start a new one</a>.</p>
			</main>
		</div>
	}
}

templ newConversationPage(convos []convoVM, profiles []profileVM) {
	@layout("New chat — Reeve") {
		<div class="app">
			@sidebar(convos)
			<main class="main">
				<header class="conv-head">New chat</header>
				<div class="new-list">
					if len(profiles) == 0 {
						<p class="muted pad">No profiles available. Create one in the iOS app or via the API.</p>
					}
					for _, p := range profiles {
						<form method="post" action="/new">
							<input type="hidden" name="profile_id" value={ p.ID }/>
							<button type="submit" class="profile-pick">
								<span class="profile-name">{ p.Name }</span>
								if p.Description != "" {
									<span class="profile-desc">{ p.Description }</span>
								}
							</button>
						</form>
					}
				</div>
			</main>
		</div>
	}
}

// settingsShell wraps the settings pages with a header that links back to the
// chats and to the settings home.
templ settingsShell(title string) {
	@layout(title + " — Reeve") {
		<div class="settings">
			<header class="settings-head">
				<a class="brand" href="/chats">← Chats</a>
				<a class="settings-title" href="/settings">Settings</a>
			</header>
			<div class="settings-body">
				{ children... }
			</div>
		</div>
	}
}

templ settingsPage() {
	@settingsShell("Settings") {
		<nav class="settings-nav">
			<a class="settings-item" href="/settings/providers">
				<span class="settings-item-name">Providers &amp; models</span>
				<span class="settings-item-desc">Connect an LLM provider and enable models.</span>
			</a>
			<a class="settings-item" href="/settings/profiles">
				<span class="settings-item-name">Profiles</span>
				<span class="settings-item-desc">Personas: system prompt and defaults.</span>
			</a>
			<a class="settings-item" href="/settings/embedder">
				<span class="settings-item-name">Embedder</span>
				<span class="settings-item-desc">Backend for semantic history search.</span>
			</a>
			<a class="settings-item" href="/settings/langfuse">
				<span class="settings-item-name">Langfuse</span>
				<span class="settings-item-desc">Optional tracing of model calls.</span>
			</a>
			<a class="settings-item" href="/settings/cost">
				<span class="settings-item-name">Cost</span>
				<span class="settings-item-desc">Recorded model spend per provider.</span>
			</a>
		</nav>
	}
}

templ providersPage(provs []providerVM) {
	@settingsShell("Providers") {
		<div class="settings-section-head">
			<h1>Providers</h1>
			<a class="btn" href="/settings/providers/new">Add provider</a>
		</div>
		<div class="card-list">
			if len(provs) == 0 {
				<p class="muted">No providers yet. Add one to enable models.</p>
			}
			for _, p := range provs {
				<a class="row-card" href={ templ.SafeURL("/settings/providers/" + p.ID) }>
					<span class="row-card-title">{ p.Label }</span>
					<span class="row-card-sub">{ p.Type }</span>
				</a>
			}
		</div>
	}
}

templ providerNewPage(types []providerTypeVM, errMsg string) {
	@settingsShell("Add provider") {
		<h1>Add provider</h1>
		if errMsg != "" {
			<p class="error">{ errMsg }</p>
		}
		<form class="form" method="post" action="/settings/providers">
			<label>
				Type
				<select name="type">
					for _, t := range types {
						<option value={ t.Name }>{ t.DisplayName }</option>
					}
				</select>
			</label>
			<label>
				Label
				<input name="label" placeholder="e.g. Anthropic" autocomplete="off"/>
			</label>
			<label>
				Base URL <span class="muted">(optional; required for OpenAI-compatible endpoints)</span>
				<input name="base_url" placeholder="https://api.example.com/v1" autocomplete="off"/>
			</label>
			<label>
				API key <span class="muted">(stored encrypted)</span>
				<input name="api_key" type="password" autocomplete="off"/>
			</label>
			<div class="form-actions">
				<button type="submit">Create</button>
				<a class="btn-link" href="/settings/providers">Cancel</a>
			</div>
		</form>
	}
}

templ providerDetailPage(prov providerVM, enabled []enabledModelVM, discovered []discoveredVM, test *testVM) {
	@settingsShell(prov.Label) {
		<div class="settings-section-head">
			<h1>{ prov.Label }</h1>
			<span class="muted">{ prov.Type }</span>
		</div>
		if test != nil {
			if test.OK {
				<p class="ok">Connection OK. { itoa(test.ModelCount) } models available.</p>
			} else {
				<p class="error">{ orDefault(test.Message, "Connection failed.") }</p>
			}
		}
		<div class="settings-actions">
			<form method="post" action={ templ.SafeURL("/settings/providers/" + prov.ID + "/discover") }>
				<button type="submit">Discover models</button>
			</form>
			<form method="post" action={ templ.SafeURL("/settings/providers/" + prov.ID + "/test") }>
				<button class="btn-secondary" type="submit">Test connection</button>
			</form>
			<form method="post" action={ templ.SafeURL("/settings/providers/" + prov.ID + "/delete") } onsubmit="return confirm('Delete this provider?')">
				<button class="btn-danger" type="submit">Delete</button>
			</form>
		</div>
		<section>
			<h2>Enabled models</h2>
			if len(enabled) == 0 {
				<p class="muted">No models enabled yet. Discover models to enable some.</p>
			} else {
				<ul class="model-list">
					for _, m := range enabled {
						<li><span class="model-name">{ m.DisplayName }</span> <code>{ m.ModelID }</code></li>
					}
				</ul>
			}
		</section>
		if discovered != nil {
			<section>
				<h2>Discovered models</h2>
				if len(discovered) == 0 {
					<p class="muted">The provider returned no models.</p>
				} else {
					<form method="post" action={ templ.SafeURL("/settings/providers/" + prov.ID + "/enable") }>
						<ul class="model-list checks">
							for _, d := range discovered {
								<li>
									<label>
										<input type="checkbox" name="model_ids" value={ d.ModelID } disabled?={ d.Enabled } checked?={ d.Enabled }/>
										<span class="model-name">{ d.DisplayName }</span> <code>{ d.ModelID }</code>
										if d.Enabled {
											<span class="muted">enabled</span>
										}
									</label>
								</li>
							}
						</ul>
						<button type="submit">Enable selected</button>
					</form>
				}
			</section>
		}
	}
}

templ costPage(rows []costRowVM, grand string) {
	@settingsShell("Cost") {
		<h1>Cost</h1>
		<p class="muted">Recorded model spend per provider (since cost tracking began).</p>
		<table class="cost-table">
			<thead>
				<tr><th>Provider</th><th>Type</th><th class="num">Events</th><th class="num">Total</th></tr>
			</thead>
			<tbody>
				if len(rows) == 0 {
					<tr><td colspan="4" class="muted">No spend recorded yet.</td></tr>
				}
				for _, c := range rows {
					<tr>
						<td>{ c.Label }</td>
						<td class="muted">{ c.Type }</td>
						<td class="num">{ itoa64(c.Events) }</td>
						<td class="num">{ c.Total }</td>
					</tr>
				}
			</tbody>
			<tfoot>
				<tr><td colspan="3">Total</td><td class="num">{ grand }</td></tr>
			</tfoot>
		</table>
	}
}

templ contextsPage(conv convoVM, rows []contextRowVM) {
	@settingsShell("Contexts") {
		<div class="settings-section-head">
			<h1>Contexts</h1>
			<a class="btn-link" href={ templ.SafeURL("/c/" + conv.ID) }>Back to chat</a>
		</div>
		<p class="muted">{ conv.Title }</p>
		<div class="card-list">
			for _, c := range rows {
				<a class="row-card" href={ templ.SafeURL("/c/" + conv.ID + "/context/" + c.ID) }>
					<span class="row-card-title">
						{ c.Title }
						if c.Active {
							<span class="badge">active</span>
						}
					</span>
					<span class="row-card-sub">{ itoa(c.MessageCount) } messages · { c.Cost }</span>
				</a>
			}
		</div>
	}
}

templ contextViewPage(conv convoVM, msgs []msgVM) {
	@layout(conv.Title + " — context") {
		<div class="app">
			<main class="main">
				<header class="conv-head">
					<a class="btn-link" href={ templ.SafeURL("/c/" + conv.ID + "/contexts") }>← Contexts</a>
					<span>{ conv.Title }</span>
				</header>
				<div class="messages">
					for _, m := range msgs {
						@messageBubble(m, false)
					}
				</div>
			</main>
		</div>
	}
}

// promoteForm shows a reviewed compaction summary and a button to roll it into
// a new active context. Used on reload when a summary is already pending.
templ promoteForm(convID, messageID, summaryHTML string) {
	<div class="compact-out">
		<h2>Summary</h2>
		<div class="md compact-summary">
			@templ.Raw(summaryHTML)
		</div>
		@promoteButton(convID, messageID)
	</div>
}

templ promoteButton(convID, messageID string) {
	<form method="post" action={ templ.SafeURL("/c/" + convID + "/promote") }>
		<input type="hidden" name="message_id" value={ messageID }/>
		<button type="submit">Start fresh context from this summary</button>
	</form>
}

// compactStream opens the compaction run's SSE stream: `message` events morph
// the summary as it streams, `promote` swaps in the promote button bound to the
// new summary message, and `done` closes the connection.
templ compactStream(convID, runID string) {
	<div
		class="compact-out streaming"
		hx-ext="sse"
		sse-connect={ "/c/" + convID + "/compact/stream?run=" + runID }
		sse-close="done"
	>
		<h2>Summary</h2>
		<div class="md compact-summary" sse-swap="message"></div>
		<div class="compact-promote" sse-swap="promote"></div>
	</div>
}

templ compactPage(conv convoVM, pending *summaryVM) {
	@layout(conv.Title + " — compact") {
		<div class="app">
			<main class="main">
				<header class="conv-head">
					<a class="btn-link" href={ templ.SafeURL("/c/" + conv.ID) }>← Back</a>
					<span class="conv-title">Compact: { conv.Title }</span>
				</header>
				<div class="compact-body">
					<p class="muted">
						Compaction summarizes the current context and starts a fresh one from the summary.
						The original messages are kept and remain viewable under Contexts.
					</p>
					if pending != nil {
						@promoteForm(conv.ID, pending.MessageID, pending.HTML)
					} else {
						<form
							method="post"
							action={ templ.SafeURL("/c/" + conv.ID + "/compact") }
							hx-post={ "/c/" + conv.ID + "/compact" }
							hx-target="#compact-out"
							hx-swap="outerHTML"
						>
							<button type="submit">Run compaction</button>
						</form>
						<div id="compact-out"></div>
					}
				</div>
			</main>
		</div>
	}
}

templ resultBanner(r *testVM) {
	if r != nil {
		if r.OK {
			<p class="ok">Connection OK.</p>
		} else {
			<p class="error">{ orDefault(r.Message, "Failed.") }</p>
		}
	}
}

templ embedderPage(vm embedderVM) {
	@settingsShell("Embedder") {
		<h1>Embedder</h1>
		<p class="muted">Powers semantic history search. Point it at an embeddings backend (for example a local Ollama).</p>
		@resultBanner(vm.Result)
		<form class="form" method="post" action="/settings/embedder">
			<label class="check"><input type="checkbox" name="enabled" checked?={ vm.Enabled }/> Enabled</label>
			<label>
				Type
				<select name="type">
					if len(vm.Types) == 0 {
						<option value={ vm.Type }>{ orDefault(vm.Type, "openai") }</option>
					}
					for _, t := range vm.Types {
						<option value={ t } selected?={ t == vm.Type }>{ t }</option>
					}
				</select>
			</label>
			<label>
				Base URL
				<input name="base_url" value={ vm.BaseURL } placeholder="http://localhost:11434/v1" autocomplete="off"/>
			</label>
			<label>
				Model
				<input name="model" value={ vm.Model } placeholder="nomic-embed-text" autocomplete="off"/>
			</label>
			<label>
				Dimensions
				<input name="dimensions" type="number" value={ itoa(vm.Dimensions) }/>
			</label>
			<label>
				API key <span class="muted">{ keyHint(vm.APIKeySet) }</span>
				<input name="api_key" type="password" autocomplete="off"/>
			</label>
			<div class="form-actions">
				<button type="submit">Save</button>
			</div>
		</form>
		<div class="settings-actions">
			<form method="post" action="/settings/embedder/test"><button class="btn-secondary" type="submit">Test</button></form>
			<form method="post" action="/settings/embedder/delete" onsubmit="return confirm('Delete embedder config?')"><button class="btn-danger" type="submit">Delete</button></form>
		</div>
		<p class="muted">Unembedded messages: { itoa(vm.UnembeddedCount) } · worker { workerState(vm.WorkerActive) }</p>
	}
}

templ langfusePage(vm langfuseVM) {
	@settingsShell("Langfuse") {
		<h1>Langfuse</h1>
		<p class="muted">Optional tracing of model calls. Off unless configured and enabled.</p>
		@resultBanner(vm.Result)
		<form class="form" method="post" action="/settings/langfuse">
			<label class="check"><input type="checkbox" name="enabled" checked?={ vm.Enabled }/> Enabled</label>
			<label>
				Host
				<input name="host" value={ vm.Host } placeholder="https://us.cloud.langfuse.com" autocomplete="off"/>
			</label>
			<label>
				Public key
				<input name="public_key" value={ vm.PublicKey } autocomplete="off"/>
			</label>
			<label>
				Secret key <span class="muted">{ keyHint(vm.SecretKeySet) }</span>
				<input name="secret_key" type="password" autocomplete="off"/>
			</label>
			<div class="form-actions">
				<button type="submit">Save</button>
			</div>
		</form>
		<div class="settings-actions">
			<form method="post" action="/settings/langfuse/test"><button class="btn-secondary" type="submit">Test</button></form>
			<form method="post" action="/settings/langfuse/delete" onsubmit="return confirm('Delete Langfuse config?')"><button class="btn-danger" type="submit">Delete</button></form>
		</div>
	}
}

templ profilesPage(rows []profileRowVM) {
	@settingsShell("Profiles") {
		<div class="settings-section-head">
			<h1>Profiles</h1>
			<a class="btn" href="/settings/profiles/new">New profile</a>
		</div>
		<div class="card-list">
			if len(rows) == 0 {
				<p class="muted">No profiles yet.</p>
			}
			for _, p := range rows {
				<a class="row-card" href={ templ.SafeURL("/settings/profiles/" + p.ID) }>
					<span class="row-card-title">
						{ p.Name }
						if p.Template {
							<span class="badge">template</span>
						}
					</span>
					if p.Description != "" {
						<span class="row-card-sub">{ p.Description }</span>
					}
				</a>
			}
		</div>
	}
}

templ modelSelect(name, current string, models []modelVM) {
	<select name={ name }>
		<option value="" selected?={ current == "" }>(inherit / none)</option>
		for _, m := range models {
			<option value={ m.Value } selected?={ m.Value == current }>{ m.Label }</option>
		}
	</select>
}

templ profilePluginsPage(profileID, profileName string, rows []pluginRowVM, types []pluginOptVM) {
	@settingsShell("Plugins") {
		<div class="settings-section-head">
			<h1>Plugins</h1>
			<a class="btn-link" href={ templ.SafeURL("/settings/profiles/" + profileID) }>Back to profile</a>
		</div>
		<p class="muted">{ profileName } — pipeline runs in order. Config is JSON.</p>
		<form class="form" method="post" action={ templ.SafeURL("/settings/profiles/" + profileID + "/plugins") }>
			if len(rows) == 0 {
				<p class="muted">No plugins attached.</p>
			}
			for i, row := range rows {
				<div class="plugin-row">
					<div class="plugin-head">
						<strong>{ row.Name }</strong>
						<label class="check"><input type="checkbox" name={ "pdisabled_" + itoa(int32(i)) } checked?={ row.Disabled }/> disabled</label>
					</div>
					<input type="hidden" name={ "pname_" + itoa(int32(i)) } value={ row.Name }/>
					<textarea name={ "pconfig_" + itoa(int32(i)) } rows="3" spellcheck="false">{ row.ConfigJSON }</textarea>
				</div>
			}
			if len(rows) > 0 {
				<div class="form-actions"><button type="submit">Save pipeline</button></div>
			}
		</form>
		for i, row := range rows {
			<form method="post" action={ templ.SafeURL("/settings/profiles/" + profileID + "/plugins/remove") } class="plugin-remove">
				<input type="hidden" name="ordinal" value={ itoa(int32(i)) }/>
				<button class="msg-action" type="submit">Remove { row.Name }</button>
			</form>
		}
		<h2>Add plugin</h2>
		<form class="form-inline" method="post" action={ templ.SafeURL("/settings/profiles/" + profileID + "/plugins/add") }>
			<select name="plugin_name">
				for _, t := range types {
					<option value={ t.Name }>{ t.DisplayName }</option>
				}
			</select>
			<button type="submit">Add</button>
		</form>
	}
}

templ profileFormPage(title, action string, p profileFormVM, isNew bool) {
	@settingsShell(title) {
		<div class="settings-section-head">
			<h1>{ title }</h1>
			if !isNew {
				<a class="btn-link" href={ templ.SafeURL("/settings/profiles/" + p.ID + "/plugins") }>Plugins</a>
			}
		</div>
		<form class="form" method="post" action={ templ.SafeURL(action) }>
			<label>
				Name
				<input name="name" value={ p.Name } autocomplete="off"/>
			</label>
			<label>
				Description <span class="muted">(optional)</span>
				<input name="description" value={ p.Description } autocomplete="off"/>
			</label>
			<label>
				System prompt
				<textarea name="system_message" rows="10">{ p.SystemMessage }</textarea>
			</label>
			if !isNew {
				<h2>Default model</h2>
				<label>
					Model new conversations use
					@modelSelect("default_model", p.DefaultModel, p.Models)
				</label>
				<h2>Compaction</h2>
				<label>
					Model
					@modelSelect("compression_model", p.CompressionModel, p.Models)
				</label>
				<label>
					Mode
					<select name="compression_mode">
						<option value="" selected?={ p.CompressionMode == "" }>(default)</option>
						<option value="REPLACE" selected?={ p.CompressionMode == "REPLACE" }>Replace</option>
						<option value="APPEND" selected?={ p.CompressionMode == "APPEND" }>Append</option>
					</select>
				</label>
				<label>
					Guide <span class="muted">(prompt for the summary)</span>
					<textarea name="compression_guide" rows="3">{ p.CompressionGuide }</textarea>
				</label>
				<h2>Auto-title</h2>
				<label>
					Model
					@modelSelect("title_model", p.TitleModel, p.Models)
				</label>
				<label>
					Guide
					<textarea name="title_guide" rows="2">{ p.TitleGuide }</textarea>
				</label>
			}
			<div class="form-actions">
				<button type="submit">
					if isNew {
						Create
					} else {
						Save
					}
				</button>
				<a class="btn-link" href="/settings/profiles">Cancel</a>
			</div>
		</form>
		if !isNew {
			<form class="danger-zone" method="post" action={ templ.SafeURL("/settings/profiles/" + p.ID + "/delete") } onsubmit="return confirm('Delete this profile?')">
				<button class="btn-danger" type="submit">Delete profile</button>
			</form>
		}
	}
}

// elicitForm renders an MCP elicitation prompt mid-stream. Field inputs are
// named field_<name> so they don't collide with the action button; the chosen
// action rides the submit button's value. htmx posts it and swaps the form away
// (empty response, outerHTML), after which the paused run resumes on the open
// SSE stream. Without JS the form POSTs and redirects back to the chat.
templ elicitForm(convID, eid, message string, fields []elicitField) {
	<form
		class="elicit-card"
		method="post"
		action={ templ.SafeURL("/c/" + convID + "/elicit/" + eid) }
		hx-post={ "/c/" + convID + "/elicit/" + eid }
		hx-swap="outerHTML"
	>
		<p class="elicit-msg">{ message }</p>
		for _, f := range fields {
			<label class={ templ.KV("check", f.Type == "checkbox") }>
				{ f.Label }
				if f.Type == "checkbox" {
					<input type="checkbox" name={ "field_" + f.Name } value="true"/>
				} else {
					<input type={ f.Type } name={ "field_" + f.Name } autocomplete="off"/>
				}
			</label>
		}
		<div class="elicit-actions">
			<button type="submit" name="action" value="accept">Submit</button>
			<button type="submit" class="btn-secondary" name="action" value="decline">Decline</button>
		</div>
	</form>
}

templ messageBubble(m msgVM, showActions bool) {
	<div class={ "msg", m.Role }>
		<div class="md">
			for _, src := range m.Images {
				<img class="attachment" src={ src } alt="attachment" loading="lazy"/>
			}
			@templ.Raw(m.HTML)
		</div>
		if showActions {
			<div class="msg-actions">
				<a class="msg-action" href={ templ.SafeURL("/c/" + m.ConvID + "/message/" + m.ID + "/edit") }>Edit</a>
				if m.Role == "assistant" && m.ParentID != "" {
					<form method="post" action={ templ.SafeURL("/c/" + m.ConvID + "/regenerate") }>
						<input type="hidden" name="parent_message_id" value={ m.ParentID }/>
						<button class="msg-action" type="submit">Regenerate</button>
					</form>
				}
			</div>
		}
	</div>
}

templ editMessagePage(convID, mid, content string) {
	@layout("Edit message — Reeve") {
		<div class="settings">
			<header class="settings-head">
				<a class="brand" href={ templ.SafeURL("/c/" + convID) }>← Back to chat</a>
			</header>
			<div class="settings-body">
				<h1>Edit message</h1>
				<form class="form" method="post" action={ templ.SafeURL("/c/" + convID + "/message/" + mid + "/edit") }>
					<label>
						Content
						<textarea name="content" rows="12">{ content }</textarea>
					</label>
					<div class="form-actions">
						<button type="submit">Save</button>
						<a class="btn-link" href={ templ.SafeURL("/c/" + convID) }>Cancel</a>
					</div>
				</form>
			</div>
		</div>
	}
}

// assistantStream is appended after a send (and rendered on a no-JS reload with
// ?run set). It opens the run's SSE stream via htmx: `message` events morph the
// .md element as deltas arrive, `elicit` events drop an inline prompt into the
// host, and `done` closes the connection.
templ assistantStream(convID, runID string) {
	<div
		class="msg assistant streaming"
		hx-ext="sse"
		sse-connect={ "/c/" + convID + "/stream?run=" + runID }
		sse-close="done"
	>
		<div class="md" sse-swap="message"></div>
		<div class="elicit-host" sse-swap="elicit"></div>
	</div>
}

templ composer(convID string, current pickerModelVM) {
	<form
		id="composer"
		class="composer"
		method="post"
		enctype="multipart/form-data"
		action={ templ.SafeURL("/c/" + convID + "/send") }
		hx-post={ "/c/" + convID + "/send" }
		hx-target="#messages"
		hx-swap="beforeend"
		hx-encoding="multipart/form-data"
		hx-on::after-request="this.reset()"
	>
		<div class="composer-box">
			<label class="composer-attach" title="Attach image" aria-label="Attach image">
				<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
					<path d="M21.44 11.05l-9.19 9.19a6 6 0 0 1-8.49-8.49l9.19-9.19a4 4 0 0 1 5.66 5.66l-9.2 9.19a2 2 0 0 1-2.83-2.83l8.49-8.48"></path>
				</svg>
				<input id="composer-file" type="file" name="file" accept="image/*"/>
			</label>
			<textarea name="message" rows="1" placeholder="Message Reeve…"></textarea>
			<button class="composer-send" type="submit" title="Send" aria-label="Send">
				<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
					<path d="M12 19V5M5 12l7-7 7 7"></path>
				</svg>
			</button>
		</div>
		<div class="composer-tools">
			@modelChip(convID, current)
		</div>
	</form>
}

// modelChip is the composer's current-model button. It opens the rich picker
// overlay (htmx → #modal); without JS it links to the standalone picker page.
templ modelChip(convID string, m pickerModelVM) {
	<button
		type="button"
		id="composer-model-chip"
		class="model-chip"
		hx-get={ "/c/" + convID + "/model" }
		hx-target="#modal"
		hx-swap="innerHTML"
	>
		if m.Value == "" {
			<span class="model-chip-name">No models</span>
		} else {
			<span class="model-chip-name">{ m.DisplayName }</span>
			@capBadges(m.Caps)
		}
		<svg class="model-chip-caret" width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><path d="M6 9l6 6 6-6"></path></svg>
	</button>
}

templ conversationPage(convos []convoVM, conv convoVM, msgs []msgVM, current pickerModelVM, runID string) {
	@layout(conv.Title + " — Reeve") {
		<div class="app">
			@sidebar(convos)
			<main class="main">
				<header class="conv-head">
					<span class="conv-title">{ conv.Title }</span>
					<span class="conv-actions">
						<a class="conv-link" href={ templ.SafeURL("/c/" + conv.ID + "/settings") }>Settings</a>
						<a class="conv-link" href={ templ.SafeURL("/c/" + conv.ID + "/compact") }>Compact</a>
						<a class="conv-link" href={ templ.SafeURL("/c/" + conv.ID + "/contexts") }>Contexts</a>
					</span>
				</header>
				<div id="messages" class="messages">
					for _, m := range msgs {
						@messageBubble(m, true)
					}
					if runID != "" {
						@assistantStream(conv.ID, runID)
					}
				</div>
				@composer(conv.ID, current)
			</main>
		</div>
		<div id="modal"></div>
	}
}

// capBadges renders the compact capability glyphs used on chips and rows.
templ capBadges(c capsVM) {
	<span class="cap-badges">
		if c.Thinking {
			<span class="cap cap-thinking" title="Thinking">◆</span>
		}
		if c.Vision {
			<span class="cap cap-vision" title="Vision">●</span>
		}
		if c.ToolUse {
			<span class="cap cap-tools" title="Tool use">⚒</span>
		}
		if c.PromptCaching {
			<span class="cap cap-cache" title="Prompt caching">⚡</span>
		}
	</span>
}

// modelMetaStrip is the per-row metadata line: context window, cost bucket,
// knowledge cutoff, and capability badges.
templ modelMetaStrip(m pickerModelVM) {
	<span class="meta-strip">
		if m.ContextLabel != "" {
			<span class="meta-chip" title="Context window">{ m.ContextLabel }</span>
		}
		if m.CostBucket != "" {
			<span class="meta-chip meta-cost" title={ m.CostHint }>{ m.CostBucket }</span>
		}
		if m.Cutoff != "" {
			<span class="meta-chip" title="Knowledge cutoff">{ m.Cutoff }</span>
		}
		@capBadges(m.Caps)
	</span>
}

// modelRow is one selectable model. It posts the selection; htmx swaps the
// composer chip and dismisses the overlay, while no-JS submits and redirects.
templ modelRow(convID string, m pickerModelVM) {
	<form
		method="post"
		action={ templ.SafeURL("/c/" + convID + "/model") }
		hx-post={ "/c/" + convID + "/model" }
		hx-target="#composer-model-chip"
		hx-swap="outerHTML"
		class="model-row-form"
	>
		<input type="hidden" name="model" value={ m.Value }/>
		<button type="submit" class={ "model-row", templ.KV("selected", m.Selected), templ.KV("disabled", m.Disabled) } disabled?={ m.Disabled }>
			<span class="model-row-head">
				<span class="model-row-name">{ m.DisplayName }</span>
				if m.Selected {
					<svg class="model-row-check" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6L9 17l-5-5"></path></svg>
				}
			</span>
			@modelMetaStrip(m)
			if m.Disabled {
				<span class="model-row-needs">Needs: { strings.Join(m.Missing, ", ") }</span>
			}
		</button>
	</form>
}

// modelPickerList is the grouped body shared by the overlay and the no-JS page.
templ modelPickerList(data pickerData) {
	if data.Total == 0 {
		<p class="muted pad">No models enabled. Add a provider and enable models under <a href="/settings/providers">Settings → Providers</a>.</p>
	}
	for _, g := range data.Groups {
		<section class="model-group">
			<header class="model-group-head">{ g.Label }</header>
			<div class="model-group-rows">
				for _, m := range g.Models {
					@modelRow(data.ConvID, m)
				}
			</div>
		</section>
	}
}

// modelPickerModal is the htmx overlay. Clicking the backdrop or the close
// button empties #modal (the overlay host) to dismiss it.
templ modelPickerModal(data pickerData) {
	<div class="modal-backdrop" onclick="document.getElementById('modal').innerHTML=''">
		<div class="modal-panel model-picker" onclick="event.stopPropagation()">
			<header class="modal-head">
				<span class="modal-title">Model</span>
				<span class="muted">{ itoa(int32(data.Total)) } across { itoa(int32(len(data.Groups))) } providers</span>
				<button type="button" class="modal-close" onclick="document.getElementById('modal').innerHTML=''" aria-label="Close">✕</button>
			</header>
			<div class="modal-body">
				@modelPickerList(data)
			</div>
		</div>
	</div>
}

// --- conversation settings ---

templ convSettingsPage(vm convSettingsVM) {
	@layout(vm.Title + " — settings") {
		<div class="settings">
			<header class="settings-head">
				<a class="brand" href={ templ.SafeURL("/c/" + vm.ConvID) }>← Back to chat</a>
			</header>
			<div class="settings-body">
				<h1>Conversation settings</h1>
				<p class="muted">{ vm.Title }</p>
				<nav class="tabs">
					<a class={ "tab", templ.KV("active", vm.Tab == "call") } href={ templ.SafeURL("/c/" + vm.ConvID + "/settings?tab=call") }>Call settings</a>
					<a class={ "tab", templ.KV("active", vm.Tab == "plugins") } href={ templ.SafeURL("/c/" + vm.ConvID + "/settings?tab=plugins") }>Plugins</a>
				</nav>
				if vm.Tab == "plugins" {
					@convPluginsTab(vm)
				} else {
					@convCallTab(vm)
				}
			</div>
		</div>
	}
}

templ convCallTab(vm convSettingsVM) {
	<p class="muted settings-note">Any field left blank inherits from the profile (and below). The placeholder shows the value it inherits.</p>
	<form class="form" method="post" action={ templ.SafeURL("/c/" + vm.ConvID + "/settings") }>
		<h2>Sampling</h2>
		@numField("Temperature", vm.Temperature, "0.01")
		@numField("Top P", vm.TopP, "0.01")
		@numField("Max output tokens", vm.MaxOutputTokens, "1")
		@numField("Top K", vm.TopK, "1")
		<label>
			Stop sequences <span class="muted">(comma-separated)</span>
			<input name={ vm.StopSequences.Name } value={ vm.StopSequences.Value } placeholder={ vm.StopSequences.Inherited } autocomplete="off"/>
		</label>
		<h2>Thinking</h2>
		@triSelect("Enabled", vm.ThinkingEnabled)
		@numField("Budget tokens", vm.ThinkingBudget, "256")
		<h2>Caching</h2>
		@triSelect("Explicit cache", vm.ExplicitCache)
		<h2>History</h2>
		@triSelect("Include thinking in history", vm.IncludeThinking)
		if vm.DriverType == "anthropic" {
			<h2>Anthropic</h2>
			@triSelect("Prompt cache enabled", vm.AnthCacheEnabled)
		}
		if vm.DriverType == "openai-compatible" {
			<h2>OpenAI</h2>
			@numField("Seed", vm.OAISeed, "1")
			@numField("Frequency penalty", vm.OAIFreqPenalty, "0.1")
			@numField("Presence penalty", vm.OAIPresPenalty, "0.1")
			@triSelect("Parallel tool calls", vm.OAIParallelTools)
		}
		if vm.DriverType == "google" {
			<h2>Google</h2>
			@numField("Candidate count", vm.GoogCandidates, "1")
		}
		<div class="form-actions">
			<button type="submit">Save</button>
			<a class="btn-link" href={ templ.SafeURL("/c/" + vm.ConvID) }>Back to chat</a>
		</div>
	</form>
}

templ numField(label string, f callFieldVM, step string) {
	<label>
		{ label }
		if f.Inherited != "" {
			<span class="muted">(inherits { f.Inherited })</span>
		}
		<input type="number" step={ step } name={ f.Name } value={ f.Value } placeholder={ orPlaceholder(f.Inherited) } autocomplete="off"/>
	</label>
}

templ triSelect(label string, f triFieldVM) {
	<label>
		{ label }
		<select name={ f.Name }>
			<option value="" selected?={ f.State == "" }>Inherit{ triInheritLabel(f.Inherited) }</option>
			<option value="on" selected?={ f.State == "on" }>On</option>
			<option value="off" selected?={ f.State == "off" }>Off</option>
		</select>
	</label>
}

templ convPluginsTab(vm convSettingsVM) {
	<p class="muted settings-note">The merged pipeline runs in order. Inherited plugins come from the profile; you can disable them here or add conversation-only overrides.</p>
	<div class="card-list">
		if len(vm.Plugins) == 0 {
			<p class="muted">No plugins in the pipeline.</p>
		}
		for _, p := range vm.Plugins {
			<div class="plugin-row">
				<div class="plugin-head">
					<strong class={ templ.KV("strike", p.Disabled) }>{ p.Display }</strong>
					if p.Source == "Override" {
						<span class="badge badge-override">override</span>
					} else {
						<span class="badge">inherited</span>
					}
					if p.Disabled {
						<span class="badge badge-warn">disabled</span>
					}
				</div>
				<code class="plugin-name">{ p.Name }</code>
				if !p.Disabled {
					<details class="plugin-config">
						<summary>Config</summary>
						<form method="post" action={ templ.SafeURL("/c/" + vm.ConvID + "/plugins/override") }>
							<input type="hidden" name="action" value="config"/>
							<input type="hidden" name="plugin_name" value={ p.Name }/>
							<textarea name="config" rows="4" spellcheck="false" placeholder="{}">{ p.ConfigJSON }</textarea>
							<button class="btn-secondary" type="submit">Save config</button>
						</form>
					</details>
				}
				<div class="plugin-actions">
					if p.Disabled {
						@pluginActionForm(vm.ConvID, "restore", p.Name, "Restore")
					} else if p.Source == "Override" {
						@pluginActionForm(vm.ConvID, "remove", p.Name, "Remove override")
					} else {
						@pluginActionForm(vm.ConvID, "disable", p.Name, "Disable here")
					}
				</div>
			</div>
		}
	</div>
	if len(vm.Addable) > 0 {
		<h2>Add conversation plugin</h2>
		<form class="form-inline" method="post" action={ templ.SafeURL("/c/" + vm.ConvID + "/plugins/override") }>
			<input type="hidden" name="action" value="add"/>
			<select name="plugin_name">
				for _, t := range vm.Addable {
					<option value={ t.Name }>{ t.DisplayName }</option>
				}
			</select>
			<button type="submit">Add</button>
		</form>
	}
}

templ pluginActionForm(convID, action, name, label string) {
	<form method="post" action={ templ.SafeURL("/c/" + convID + "/plugins/override") }>
		<input type="hidden" name="action" value={ action }/>
		<input type="hidden" name="plugin_name" value={ name }/>
		<button class="msg-action" type="submit">{ label }</button>
	</form>
}

// modelPickerPage is the no-JS standalone picker.
templ modelPickerPage(data pickerData) {
	@layout("Model — Reeve") {
		<div class="settings">
			<header class="settings-head">
				<a class="brand" href={ templ.SafeURL("/c/" + data.ConvID) }>← Back to chat</a>
			</header>
			<div class="settings-body">
				<h1>Model</h1>
				@modelPickerList(data)
			</div>
		</div>
	}
}
