/bin/
*.test
*.out
.env
.env.local

# `go build ./cmd/spaltd` output + the file storage root that
# defaults to ./spaltd-data when SPALT_DATA_DIR is unset.
/spaltd
/spaltd-data/

# `cmd/discover-constraints --out auto` dumps per-run JSON here. These
# files embed verbatim provider error messages which have leaked an API
# key in the past; keep them out of the repo entirely (review locally,
# never commit).
/internal/modelmeta/constraint_probes/

# IDE
.idea/
.vscode/
*.swp

# macOS
.DS_Store

# Per-user Claude Code state — user-level settings + scheduled-task locks
# don't belong in the repo.
.claude/

# Swift build artifacts and the xcodegen-generated project (project.yml is the
# source of truth). Naming-agnostic so they hold across the client rename.
clients/**/.build/
clients/**/.swiftpm/
clients/**/*.xcodeproj/
